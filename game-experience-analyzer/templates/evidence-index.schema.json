{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paranoia.skills/game-experience-analyzer/evidence-index.schema.json",
  "title": "Game Experience Analyzer Evidence Index",
  "type": "object",
  "required": [
    "sample_scope_gate",
    "evidence_index",
    "important_judgments"
  ],
  "additionalProperties": false,
  "properties": {
    "sample_scope_gate": {
      "type": "object",
      "required": [
        "sample_boundary",
        "supported_judgment_scope",
        "unsupported_judgment_scope",
        "key_unknowns"
      ],
      "additionalProperties": false,
      "properties": {
        "sample_boundary": {
          "type": "string",
          "minLength": 1
        },
        "supported_judgment_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "unsupported_judgment_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "key_unknowns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "evidence_index": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "important_judgments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/judgment_item"
      }
    }
  },
  "$defs": {
    "event_type": {
      "type": "string",
      "enum": [
        "hook_peak",
        "feature_exposure",
        "feature_unlock",
        "first_use",
        "reward_claim",
        "failure_signal",
        "confusion_signal",
        "monetization_prompt",
        "decision_point",
        "shareable_moment",
        "control_release",
        "loop_closure",
        "access_blocked"
      ]
    },
    "source_type": {
      "type": "string",
      "enum": [
        "screenshot",
        "video_file",
        "video_url",
        "trailer_pv",
        "paid_creative",
        "store_page",
        "user_context"
      ]
    },
    "evidence_item": {
      "type": "object",
      "required": [
        "evidence_id",
        "source_id",
        "source_type",
        "region",
        "observed_fact",
        "event_type",
        "supports_judgment",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^E[0-9]{3,}$"
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "$ref": "#/$defs/source_type"
        },
        "timestamp": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9]{2}:[0-9]{2}(:[0-9]{2}(\\.[0-9]{1,3})?)?$"
        },
        "time_range": {
          "type": [
            "string",
            "null"
          ]
        },
        "frame_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "image_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "visible_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "observed_fact": {
          "type": "string",
          "minLength": 1
        },
        "event_type": {
          "$ref": "#/$defs/event_type"
        },
        "supports_judgment": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "uncertainty_note": {
          "type": [
            "string",
            "null"
          ]
        },
        "extraction_method": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "direct_observation",
            "frame_sample",
            "ocr",
            "page_metadata",
            "user_provided",
            null
          ]
        }
      }
    },
    "judgment_item": {
      "type": "object",
      "required": [
        "judgment_id",
        "claim",
        "judgment_type",
        "evidence_refs",
        "confidence",
        "unsupported_by_sample"
      ],
      "additionalProperties": false,
      "properties": {
        "judgment_id": {
          "type": "string",
          "pattern": "^J[0-9]{3,}$"
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "judgment_type": {
          "type": "string",
          "enum": [
            "finding",
            "risk",
            "recommendation",
            "unknown",
            "validation"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^E[0-9]{3,}$"
          },
          "uniqueItems": true
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "unsupported_by_sample": {
          "type": "boolean"
        },
        "unknowns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "examples": [
    {
      "sample_scope_gate": {
        "sample_boundary": "1 条 30 秒 PV，可访问；没有完整实机流程。",
        "supported_judgment_scope": [
          "首秒钩子",
          "卖点复述",
          "可传播峰值"
        ],
        "unsupported_judgment_scope": [
          "操作手感",
          "确定销量",
          "D7 留存"
        ],
        "key_unknowns": [
          "Demo 转化",
          "Steam 愿望单"
        ]
      },
      "evidence_index": [
        {
          "evidence_id": "E001",
          "source_id": "pv_01",
          "source_type": "trailer_pv",
          "timestamp": "00:00:03",
          "time_range": "00:00:02-00:00:05",
          "frame_id": "F003",
          "image_id": null,
          "region": "full frame",
          "visible_text": null,
          "observed_fact": "第 3 秒出现可控角色与巨大敌人对峙。",
          "event_type": "hook_peak",
          "supports_judgment": "PV 首秒钩子明确。",
          "confidence": 0.9,
          "uncertainty_note": "",
          "extraction_method": "frame_sample"
        }
      ],
      "important_judgments": [
        {
          "judgment_id": "J001",
          "claim": "PV 有强视觉钩子，但尚未证明核心循环。",
          "judgment_type": "finding",
          "evidence_refs": [
            "E001"
          ],
          "confidence": 0.78,
          "unsupported_by_sample": false,
          "unknowns": [
            "连续实机操作"
          ],
          "recommended_action": "补 60 秒实机片段验证可玩性证明。"
        }
      ]
    }
  ]
}
